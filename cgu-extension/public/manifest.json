{
  "manifest_version": 3,
  "name": "LuEtApprouvé",
  "version": "1.0.0",
  "description": "Votre ange gardien juridique pour les Conditions Générales.",
  "action": {
    "default_popup": "index.html",
    "default_title": "Voir l'analyse"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "webNavigation",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://luetapprouve.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
